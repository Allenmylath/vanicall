# Copy to .env for local development (loaded manually; not committed).
# In production these are set as Fly.io secrets, not in this file.

DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
JWT_SECRET=change-me-to-a-long-random-string

# Web server — Cloudflare Realtime SFU (rtc.live.cloudflare.com).
# App ID + App Secret come from your Realtime app (Dashboard or API).
CF_APP_ID=your_realtime_app_id
CF_APP_SECRET=your_realtime_app_secret

# Reconciler — Cloudflare usage analytics (GraphQL).
CF_ACCOUNT_ID=your_cloudflare_account_id
# A SEPARATE Cloudflare API token with the "Account Analytics" permission.
CF_ANALYTICS_API_TOKEN=

# Optional
PORT=8080
RUST_LOG=info,tower_http=info

# Reconciler tuning (all optional)
# RECONCILE_INTERVAL_SECS=600   # set => loop forever; unset => single pass then exit
# RECONCILE_SETTLE_SECS=300     # wait this long after a call ends before billing it
# RECONCILE_GIVE_UP_SECS=86400  # after this, bill as 0 if CF still has no data
# RECONCILE_BATCH=200           # max sessions processed per pass
